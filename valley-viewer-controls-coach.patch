diff --git a/web/src/styles.css b/web/src/styles.css
--- a/web/src/styles.css
+++ b/web/src/styles.css
@@ -826,3 +826,88 @@
     left: 12px;
   }
 }
+
+/* First-run camera controls coach */
+.controls-coach {
+  position: absolute;
+  inset: 0;
+  z-index: 20;
+  display: grid;
+  place-items: center;
+  padding: 20px;
+  background: rgba(6, 12, 16, 0.62);
+  backdrop-filter: blur(2px);
+}
+
+.controls-coach-card {
+  width: min(440px, calc(100vw - 40px));
+  border-radius: 14px;
+  padding: 20px;
+}
+
+.coach-rows {
+  display: grid;
+  gap: 8px;
+  margin-top: 14px;
+}
+
+.coach-row {
+  display: grid;
+  grid-template-columns: 112px 1fr;
+  align-items: center;
+  gap: 14px;
+  padding: 11px 13px;
+  border: 1px solid rgba(226, 239, 235, 0.12);
+  border-radius: 10px;
+  background: rgba(255, 255, 255, 0.04);
+}
+
+.coach-keys {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 5px;
+  justify-content: center;
+}
+
+.coach-row strong {
+  display: block;
+  color: #f5fbfa;
+  font-size: 13.5px;
+}
+
+.coach-row span {
+  display: block;
+  margin-top: 2px;
+  color: var(--text-muted);
+  font-size: 11px;
+  font-weight: 600;
+}
+
+.kbd {
+  display: inline-grid;
+  place-items: center;
+  min-width: 24px;
+  height: 24px;
+  padding: 0 7px;
+  border: 1px solid rgba(123, 211, 199, 0.4);
+  border-bottom-width: 3px;
+  border-radius: 6px;
+  color: var(--accent-strong);
+  background: rgba(123, 211, 199, 0.1);
+  font-size: 11px;
+  font-weight: 700;
+  text-transform: capitalize;
+}
+
+.coach-cta {
+  width: 100%;
+  height: 44px;
+  margin-top: 16px;
+  border: none;
+  border-radius: 9px;
+  color: #06110f;
+  background: linear-gradient(180deg, #c9fff6, #7bd3c7);
+  font-size: 14px;
+  font-weight: 800;
+  cursor: pointer;
+}
